{
  "name": "umbra-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier -w .",
    "gen": "openapi-typescript ../docs/api/openapi.yaml -o ../packages/contracts/openapi.ts && mkdir -p ./contracts && cp ../packages/contracts/openapi.ts ./contracts/openapi.ts && cp ../packages/contracts/client.ts ./contracts/client.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-select": "2.1.2",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slot": "1.1.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "lucide-react": "0.462.0",
    "next": "14.2.35",
    "openapi-fetch": "0.10.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.3.3",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "autoprefixer": "10.4.20",
    "@playwright/test": "1.47.2",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "openapi-typescript": "6.7.3",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.14",
    "typescript": "5.5.4"
  }
}
